{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "outDir": "./dist",
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,

    // *** Requerido para decoradores ***
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Opcional, ayuda a evitar rarezas con campos + decoradores
    "useDefineForClassFields": false
  },
  "include": ["src/**/*"]
}
